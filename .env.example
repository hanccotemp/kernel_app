# Proveedor de IA (capa intercambiable). Default: mock (corre sin API key).
# Opciones: mock | deepseek | anthropic | openai
AI_PROVIDER=mock

# Puerto del servidor
PORT=3000

# --- Claves por proveedor (solo la del proveedor elegido es necesaria) ---

# DeepSeek (proveedor primario sugerido por costo)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Anthropic (motor de demo de alta calidad / respaldo)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (alternativa)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Fuente bíblica para Aurora (Capa 3) ---
# YouVersion Platform: texto LICENCIADO (RVR1960 en ES). Camino legal para RVR1960.
# 1) Crea una app y obtén la key en https://developers.youversion.com
# 2) Acepta las licencias de las versiones que usarás.
# 3) Encuentra los IDs con: node scripts/youversion-setup.js
# Sin estas variables, Aurora usa un respaldo de DOMINIO PÚBLICO (RVR1909), no RVR1960.
# YOUVERSION_APP_KEY=
# YOUVERSION_BIBLE_ID_ES=   # ID de Reina-Valera 1960
# YOUVERSION_BIBLE_ID_PT=   # ID de la versión en portugués elegida
# YOUVERSION_BIBLE_ID_EN=   # ID de la versión en inglés elegida
